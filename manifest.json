{
  "id": "officer-elections",
  "name": "Officer Elections",
  "version": "1.1.0",
  "description": "Run officer elections with candidate nominations, secret ballots, majority or ranked-choice voting, and formal result certification.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "organization",
  "tags": ["elections", "voting", "officers", "governance", "org"],
  "data_access": {
    "reads": ["family.members", "family.groups"],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "storage": "db",
  "row_policies": {
    "settings": {
      "kind": "app_config"
    },
    "oe_elections": {
      "kind": "owner_or_visibility",
      "member_column": "created_by",
      "visibility_column": "visibility",
      "everyone_values": ["everyone"],
      "write_privileged_only": true,
      "bypass_group_setting": { "settings_table": "settings", "settings_key": "officials_group_id" }
    },
    "oe_candidates": {
      "kind": "owner_or_visibility",
      "member_column": "nominated_by",
      "visibility_column": "visibility",
      "everyone_values": ["everyone"],
      "write_privileged_only": true,
      "bypass_group_setting": { "settings_table": "settings", "settings_key": "officials_group_id" }
    },
    "oe_ballots": {
      "kind": "endpoint_only",
      "read": "none"
    },
    "oe_ballot_items": {
      "kind": "endpoint_only",
      "read": "none"
    },
    "oe_ballot_receipts": {
      "kind": "owner_only",
      "member_column": "voter_id",
      "adults_bypass": false,
      "member_can_update": false,
      "endpoint_writes_only": true
    }
  },
  "anonymous_ballot": {
    "receipt_table": "oe_ballot_receipts",
    "session_column": "election_id",
    "member_column": "voter_id",
    "created_at_column": "created_at",
    "ballot_table": "oe_ballots",
    "ballot_session_column": "election_id",
    "ballot_id_column": "id",
    "ballot_created_at_column": "created_at",
    "items_table": "oe_ballot_items",
    "item_id_column": "id",
    "ballot_fk_column": "ballot_id",
    "candidate_column": "candidate_id",
    "rank_column": "rank",
    "session_table": "oe_elections",
    "session_id_column": "id",
    "session_status_column": "status",
    "session_open_values": ["voting"],
    "result_visible_values": ["closed", "certified"],
    "session_deadline_column": "voting_deadline",
    "session_voting_method_column": "voting_method",
    "majority_method_values": ["majority"],
    "ranked_method_values": ["ranked_choice"],
    "candidate_table": "oe_candidates",
    "candidate_session_column": "election_id",
    "candidate_id_column": "id"
  },
  "admin_config": {
    "settings_table": "settings",
    "keys": ["officials_group_id"]
  },
  "nav": { "label": "Elections" },
  "icon": "🗳️"
}
